@prefix ex: <http://example.com/> .
@prefix owl: <http://www.w3.org/2002/07/owl#> .
@prefix sh: <http://www.w3.org/ns/shacl#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix geo: <http://www.opengis.net/ont/geosparql#> .
@prefix geof: <http://www.opengis.net/def/function/geosparql/> .
@prefix geov: <http://www.opengis.net/def/geosparql/validator/> .

geov:sfEquals a sh:NodeShape ;
    sh:targetSubjectsOf geo:sfEquals ;
    sh:targetClass geo:Feature ;
    sh:validator [
        a sh:SPARQLAskValidator ;
        sh:ask  """
            ask
            where {
                ?f <http://www.opengis.net/ont/geosparql#sfEquals> ?f2 .
                ?f <http://www.opengis.net/ont/geosparql#hasGeometry> ?fgeom . ?fgeom <http://www.opengis.net/ont/geosparql#asWKT> ?fgwkt .
                ?f2 <http://www.opengis.net/ont/geosparql#hasGeometry> ?f2geom . ?f2geom <http://www.opengis.net/ont/geosparql#asWKT> ?f2gwkt .
                FILTER (<http://www.opengis.net/def/function/geosparql/sfEquals>(?fgwkt,?f2gwkt)=true)
            }
        """ ;
        sh:message "Features related with the property geo:sfEquals should return a consistent result when comparing their geometries using the geof:sfEquals function" ; ] 
.


geov:sfDisjoint a sh:NodeShape ;
    sh:targetSubjectsOf geo:sfDisjoint ;
    sh:targetClass geo:Feature ;
    sh:validator [
        a sh:SPARQLAskValidator ;
        sh:ask  """
            ask
            where {
                ?f <http://www.opengis.net/ont/geosparql#sfDisjoint> ?f2 .
                ?f <http://www.opengis.net/ont/geosparql#hasGeometry> ?fgeom . ?fgeom <http://www.opengis.net/ont/geosparql#asWKT> ?fgwkt .
                ?f2 <http://www.opengis.net/ont/geosparql#hasGeometry> ?f2geom . ?f2geom <http://www.opengis.net/ont/geosparql#asWKT> ?f2gwkt .
                FILTER (<http://www.opengis.net/def/function/geosparql/sfDisjoint>(?fgwkt,?f2gwkt)=true)
            }
        """ ;
        sh:message "Features related with the property geo:sfDisjoint should return a consistent result when comparing their geometries using the geof:sfDisjoint function" ; ] 
.



